{
  "permissions": {
    "allow": [
      "Skill(claude-api)",
      "Bash(AGENTS/**)",
      "Edit(AGENTS/logs/**)", "Write(AGENTS/logs/**)",
      "Edit(AGENTS/prompts/**)", "Write(AGENTS/prompts/**)",
      "Edit(AGENTS/plans/**)", "Write(AGENTS/plans/**)",
      "Edit(AGENTS/study/**)", "Write(AGENTS/study/**)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git rev-parse *)",
      "Bash(git symbolic-ref *)",
      "Bash(git ls-remote *)",
      "Bash(git branch *)",
      "Bash(git switch *)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git merge *)",
      "Bash(git remote *)",
      "Bash(git push *)",
      "Bash(gh pr *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git branch -D*)"
    ]
  },
  "hooks": {
    "SessionStart": [{ "hooks": [{ "type": "command", "command": "AGENTS/hooks/sessionstart.sh" }] }],
    "PreToolUse": [{ "matcher": "Bash", "hooks": [{ "type": "command", "command": "AGENTS/hooks/pretooluse.sh" }] }],
    "PostToolUse": [{ "matcher": "Write|Edit", "hooks": [{ "type": "command", "command": "AGENTS/hooks/posttooluse.sh", "timeout": 120 }] }],
    "TaskCreated": [{ "hooks": [{ "type": "command", "command": "AGENTS/hooks/taskcreated.sh" }] }],
    "TaskCompleted": [{ "hooks": [{ "type": "command", "command": "AGENTS/hooks/taskcompleted.sh" }] }],
    "Stop": [{ "hooks": [{ "type": "command", "command": "AGENTS/hooks/stop.sh" }] }]
  }
}
